# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-host/dbname?sslmode=require"

# Auth Secret - Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-here"

# Next.js URL - Update to your Vercel deployment URL
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_URL_INTERNAL="http://localhost:3000"

# Optional: For production, set to your actual Vercel URL
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_URL_INTERNAL="https://your-app.vercel.app"
